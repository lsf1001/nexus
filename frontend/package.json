    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.25.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
