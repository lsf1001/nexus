FROM python:3.11-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# 复制虚拟环境（如果在主机上创建）
COPY .venv /app/.venv

# 设置虚拟环境
ENV PATH="/app/.venv/bin:$PATH"

# 复制后端代码
COPY nexus/backend /app/nexus/backend

# 暴露端口
EXPOSE 8000

# 启动命令
CMD ["python", "-m", "uvicorn", "nexus.backend.main:app", "--host", "0.0.0.0", "--port", "8000"]