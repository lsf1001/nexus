# Nexus Docker 环境变量
# 复制此文件为 .env 并填写实际值

# MiniMax API 配置
# 优先级：MINIMAX_API_KEY > MiniMax_API_KEY > ANTHROPIC_AUTH_TOKEN > ANTHROPIC_API_KEY
MINIMAX_API_KEY=your-api-key-here
# 兼容 Anthropic 风格环境变量（不设 MiniMax 时可用）
# ANTHROPIC_AUTH_TOKEN=...
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_BASE=https://api.minimaxi.com/v1

# 服务端口
NEXUS_PORT=30000

# WebSocket 认证 Token
NEXUS_WS_TOKEN=nexus-default-token
