# Nexus 环境变量样例
# 复制此文件为 .env 并填写实际值
# 注意：.env 必须放仓库根或 .nexus/ 同级，启动时被 python-dotenv 加载

# === MiniMax API 凭证 ===
# 优先级：MINIMAX_API_KEY > MiniMax_API_KEY > ANTHROPIC_AUTH_TOKEN > ANTHROPIC_API_KEY
MINIMAX_API_KEY=your-api-key-here
# 兼容 Anthropic 风格环境变量（不设 MiniMax 时可用）
# ANTHROPIC_AUTH_TOKEN=...
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_BASE=https://api.minimaxi.com/v1

# === 默认模型选择 ===
# 后端 /api/model 与 CLI 默认模型都用这个。ModelConfigModal 在 UI 改的是
# models.json 里的活跃模型名，会覆盖这里的值。
MODEL_NAME=MiniMax-M3

# === 服务端口 ===
NEXUS_PORT=30000

# === WebSocket 认证 Token ===
# 后端用 NEXUS_WS_TOKEN 校验；前端 Vite 编译期只把 VITE_ 前缀的 env 暴露给
# 客户端，所以 VITE_NEXUS_WS_TOKEN 也必须设成相同值，否则前端会回退到
# nexus-default-token，WS 鉴权失败。
# 生产建议：用 openssl rand -hex 32 生成 64 位随机串。
NEXUS_WS_TOKEN=nexus-default-token
VITE_NEXUS_WS_TOKEN=nexus-default-token
